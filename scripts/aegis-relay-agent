#!/bin/sh
set -eu
INSTALL_DIR=/opt/aegis-relay-agent
ACTION=${1:-status}
compose(){ if docker compose version >/dev/null 2>&1; then docker compose -f compose.agent.yml "$@"; else docker-compose -f compose.agent.yml "$@"; fi; }
case "$ACTION" in
  status) cd "$INSTALL_DIR"; compose ps;;
  logs) cd "$INSTALL_DIR"; compose logs -f --tail=200;;
  uninstall)
    cd "$INSTALL_DIR"; compose down
    cd /; rm -rf -- "$INSTALL_DIR"
    rm -f -- /usr/local/bin/aegis-relay-agent
    echo "Agent 已卸载；控制面中的机器记录会保持失联，需由管理员手动删除。"
    ;;
  *) echo "用法: aegis-relay-agent {status|logs|uninstall}" >&2; exit 1;;
esac
